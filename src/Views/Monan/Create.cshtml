@model WebNauAn_TVU.Models.MonAn

@{
    ViewData["Title"] = "Thêm Món Ăn";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-success text-white">
            <h2 class="mb-0">Thêm Món Ăn Mới</h2>
        </div>
        <div class="card-body">
            <form asp-action="Create" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                
                <div class="row">
                    <div class="col-md-7">
                        <div class="form-group mb-3">
                            <label class="fw-bold">Tên Món Ăn</label>
                            <input asp-for="TenMon" class="form-control" placeholder="Nhập tên món..." />
                            <span asp-validation-for="TenMon" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label class="fw-bold">Mô Tả</label>
                            <input asp-for="MoTa" class="form-control" placeholder="Mô tả ngắn gọn..." />
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>
                        <div class="form-group mb-3">
                            <label class="fw-bold">Công Thức</label>
                            <textarea asp-for="CongThuc" class="form-control" rows="5" placeholder="Các bước thực hiện..."></textarea>
                            <span asp-validation-for="CongThuc" class="text-danger"></span>
                        </div>
                    </div>
                    
                    <div class="col-md-5">
                        <div class="form-group mb-3">
                            <label class="fw-bold text-primary">Chọn Ảnh Minh Họa</label>
                            
                            <input asp-for="ImageFile" type="file" class="form-control" accept="image/*" />
                            <span asp-validation-for="ImageFile" class="text-danger"></span>
                            <div class="mt-3 p-2 border rounded bg-light text-center">
                                <small class="text-muted italic">Ảnh sẽ được lưu tự động vào hệ thống</small>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4 text-center border-top pt-3">
                    <button type="submit" class="btn btn-primary btn-lg px-5">Lưu Món Ăn</button>
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-5">Hủy bỏ</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}