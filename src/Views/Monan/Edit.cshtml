@model WebNauAn_TVU.Models.MonAn

@{
    ViewData["Title"] = "Chỉnh sửa món ăn";
}

<div class="container mt-4">
    <div class="card shadow-lg border-0">
        <div class="card-header bg-warning text-dark">
            <h2 class="mb-0">Chỉnh sửa: @Model.TenMon</h2>
        </div>
        <div class="card-body">
            <form asp-action="Edit" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="UserId" /> 
                <input type="hidden" asp-for="HinhAnh" /> 

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group mb-3">
                            <label asp-for="TenMon" class="control-label fw-bold">Tên món ăn</label>
                            <input asp-for="TenMon" class="form-control" />
                            <span asp-validation-for="TenMon" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="MoTa" class="control-label fw-bold">Mô tả ngắn</label>
                            <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                            <span asp-validation-for="MoTa" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-3">
                            <label asp-for="CongThuc" class="control-label fw-bold">Công thức</label>
                            <textarea asp-for="CongThuc" class="form-control" rows="5"></textarea>
                            <span asp-validation-for="CongThuc" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="col-md-6 text-center">
                        <div class="form-group mb-3">
                            <label class="control-label fw-bold">Ảnh hiện tại</label>
                            <div class="mt-2">
                                <img src="/@Model.HinhAnh" id="preview" class="img-thumbnail shadow-sm" style="max-height: 250px; object-fit: cover;" />
                            </div>
                        </div>

                        <div class="form-group mb-3">
                            <label class="control-label fw-bold">Chọn ảnh mới (nếu muốn thay đổi)</label>
                            <input asp-for="ImageFile" type="file" class="form-control" onchange="previewImage(this)" />
                        </div>
                    </div>
                </div>

                <div class="form-group mt-4 border-top pt-3 text-center">
                    <button type="submit" class="btn btn-success px-5">Lưu thay đổi</button>
                    <a asp-action="Index" class="btn btn-secondary px-5">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        
        function previewImage(input) {
            if (input.files && input.files[0]) {
                var reader = new FileReader();
                reader.onload = function (e) {
                    $('#preview').attr('src', e.target.result);
                }
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}